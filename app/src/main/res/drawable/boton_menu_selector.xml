<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Estado presionado/seleccionado -->
    <item android:state_pressed="true" android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#FF6B9D" />
            <corners android:radius="12dp" />
            <stroke android:width="3dp" android:color="#FFD700" />
            <padding android:left="10dp" android:top="10dp"
                android:right="10dp" android:bottom="10dp" />
        </shape>
    </item>

    <!-- Estado seleccionado (cursor encima) -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#4A4A8D" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="#FFD700" />
            <padding android:left="10dp" android:top="10dp"
                android:right="10dp" android:bottom="10dp" />
        </shape>
    </item>

    <!-- Estado normal -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#162447" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#1F4068" />
            <padding android:left="10dp" android:top="10dp"
                android:right="10dp" android:bottom="10dp" />
        </shape>
    </item>

</selector>