<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FFFFFF"
    android:padding="20dp">

    <!-- Título principal de la aplicación -->
    <TextView
        android:id="@+id/texto_titulo_app"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MI APLICACIÓN"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:layout_marginBottom="30dp" />

    <!-- Contenedor para las 4 imágenes en grid 2x2 -->
    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false"
        android:layout_marginBottom="30dp">

        <!-- Primera imagen (arriba-izquierda) -->
        <ImageView
            android:id="@+id/imagen_snake"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/snake_image1"
            android:scaleType="centerCrop"
            android:layout_margin="10dp" />

        <!-- Segunda imagen (arriba-derecha) -->
        <ImageView
            android:id="@+id/imagen_dosmil"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/dosmil_image2"
            android:scaleType="centerCrop"
            android:layout_margin="10dp" />

        <!-- Tercera imagen (abajo-izquierda) -->
        <ImageView
            android:id="@+id/imagen_proxima_1"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/proxima_image3"
            android:scaleType="centerCrop"
            android:layout_margin="10dp" />

        <!-- Cuarta imagen (abajo-derecha - repetida) -->
        <ImageView
            android:id="@+id/imagen_proxima_2"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/proxima_image3"
            android:scaleType="centerCrop"
            android:layout_margin="10dp" />

    </GridLayout>

    <!-- Texto de versión -->
    <TextView
        android:id="@+id/texto_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Versión 1.0"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginBottom="10dp" />

    <!-- Texto de copyright -->
    <TextView
        android:id="@+id/texto_copyright"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="© 2024 Mi Empresa. Todos los derechos reservados."
        android:textSize="12sp"
        android:textColor="#9E9E9E" />

</LinearLayout>