<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1A1A2E"
    android:padding="30dp">

    <!-- Título del menú -->
    <TextView
        android:id="@+id/texto_titulo_menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MENU"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:layout_marginBottom="60dp"
        android:letterSpacing="0.1" />

    <!-- Botón 1: Play Games -->
    <Button
        android:id="@+id/boton_play_games"
        android:layout_width="280dp"
        android:layout_height="70dp"
        android:text="PLAY GAMES"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/boton_menu_selector"
        android:layout_marginBottom="25dp"
        android:letterSpacing="0.05" />

    <!-- Botón 2: View Scores -->
    <Button
        android:id="@+id/boton_view_scores"
        android:layout_width="280dp"
        android:layout_height="70dp"
        android:text="VIEW SCORES"
        android:textSize="20sp"
        android:textColor="#CCCCCC"
        android:textStyle="bold"
        android:background="@drawable/boton_menu_selector"
        android:layout_marginBottom="25dp"
        android:letterSpacing="0.05" />

    <!-- Botón 3: Settings -->
    <Button
        android:id="@+id/boton_settings"
        android:layout_width="280dp"
        android:layout_height="70dp"
        android:text="SETTINGS"
        android:textSize="20sp"
        android:textColor="#CCCCCC"
        android:textStyle="bold"
        android:background="@drawable/boton_menu_selector"
        android:layout_marginBottom="25dp"
        android:letterSpacing="0.05" />

    <!-- Botón 4: Help -->
    <Button
        android:id="@+id/boton_help"
        android:layout_width="280dp"
        android:layout_height="70dp"
        android:text="HELP"
        android:textSize="20sp"
        android:textColor="#CCCCCC"
        android:textStyle="bold"
        android:background="@drawable/boton_menu_selector"
        android:letterSpacing="0.05" />

</LinearLayout>