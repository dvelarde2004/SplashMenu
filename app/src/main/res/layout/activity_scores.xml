<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1A1A2E"
    android:padding="30dp">

    <!-- Título -->
    <TextView
        android:id="@+id/texto_titulo_scores"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VIEW SCORES"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:layout_marginBottom="50dp" />

    <!-- Contenedor para scores (vacío por ahora) -->
    <TextView
        android:id="@+id/texto_scores_vacio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No scores available yet\nPlay some games first!"
        android:textSize="18sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:layout_marginBottom="50dp"
        android:lineSpacingExtra="8dp" />

    <!-- Botón Volver -->
    <Button
        android:id="@+id/boton_volver_scores"
        android:layout_width="200dp"
        android:layout_height="55dp"
        android:text="BACK"
        android:textSize="16sp"
        android:textColor="#CCCCCC"
        android:background="@drawable/boton_menu_selector" />

</LinearLayout>